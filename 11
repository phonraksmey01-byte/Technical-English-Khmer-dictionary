<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Technical English–Khmer Dictionary</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Noto+Serif+Khmer:wght@400;600&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#060e1f;--navy2:#0d1b35;--navy3:#152347;
  --border:#1e3060;--orange:#ff6b35;--orange2:#ff8c5a;
  --cyan:#00d4ff;--cyan2:#7ee8fa;--green:#00e676;
  --red:#ff4560;--yellow:#ffd600;--white:#f0f4ff;
  --muted:#6b80a8;--card:#0d1b35;
  --radius:14px;--radius-sm:8px;--shadow:0 8px 32px rgba(0,0,0,.5);
}
html{scroll-behavior:smooth}
body{background:var(--navy);color:var(--white);font-family:'Outfit',sans-serif;min-height:100vh;overflow-x:hidden}
.khmer{font-family:'Noto Serif Khmer',serif}
.mono{font-family:'IBM Plex Mono',monospace}
body::before{content:'';position:fixed;inset:0;
  background:radial-gradient(ellipse 80% 50% at 20% 10%,rgba(0,212,255,.07) 0%,transparent 60%),
             radial-gradient(ellipse 60% 40% at 80% 80%,rgba(255,107,53,.07) 0%,transparent 60%);
  pointer-events:none;z-index:0}
body::after{content:'';position:fixed;inset:0;
  background-image:linear-gradient(rgba(0,212,255,.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,212,255,.03) 1px,transparent 1px);
  background-size:60px 60px;pointer-events:none;z-index:0}
 
/* ── HEADER ── */
header{position:sticky;top:0;z-index:100;background:rgba(6,14,31,.92);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);padding:0 24px}
.header-inner{max-width:1200px;margin:0 auto;height:64px;display:flex;align-items:center;gap:16px}
.logo{width:38px;height:38px;background:linear-gradient(135deg,var(--orange),var(--cyan));
  border-radius:10px;display:grid;place-items:center;font-size:20px;flex-shrink:0}
.site-title{font-size:17px;font-weight:700;letter-spacing:-.3px}
.site-subtitle{font-size:11px;color:var(--muted);margin-top:1px}
.header-right{margin-left:auto;display:flex;align-items:center;gap:10px;flex-shrink:0}
.header-badge{background:rgba(0,212,255,.1);border:1px solid rgba(0,212,255,.25);
  color:var(--cyan);font-size:11px;padding:4px 12px;border-radius:20px;white-space:nowrap}
.header-about-btn{background:none;border:1px solid var(--border);color:var(--muted);
  font-size:12px;font-weight:600;padding:6px 14px;border-radius:20px;cursor:pointer;
  font-family:'Outfit',sans-serif;transition:all .2s;white-space:nowrap}
.header-about-btn:hover{border-color:var(--orange);color:var(--orange)}
 
/* ── MAIN ── */
.page{position:relative;z-index:1}
#home-page,#group-page{max-width:1200px;margin:0 auto;padding:40px 24px}
 
/* ── HERO ── */
.hero{text-align:center;padding:48px 0 48px}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(255,107,53,.12);
  border:1px solid rgba(255,107,53,.3);color:var(--orange);font-size:12px;font-weight:600;
  letter-spacing:.8px;text-transform:uppercase;padding:6px 16px;border-radius:20px;margin-bottom:24px}
.hero h1{font-size:clamp(30px,5.5vw,58px);font-weight:800;line-height:1.1;letter-spacing:-1.5px;margin-bottom:16px}
.hero h1 span{background:linear-gradient(90deg,var(--cyan),var(--orange));-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{font-size:16px;color:var(--muted);max-width:520px;margin:0 auto 32px;line-height:1.7}
.stats-row{display:flex;gap:32px;justify-content:center;flex-wrap:wrap}
.stat{text-align:center}
.stat-n{font-size:32px;font-weight:800;font-family:'IBM Plex Mono',monospace;
  background:linear-gradient(135deg,var(--cyan),var(--cyan2));-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text}
.stat-l{font-size:12px;color:var(--muted);margin-top:2px}
 
/* ── OWNERSHIP CARD ── */
.ownership-section{margin-bottom:36px}
.own-card{
  background:linear-gradient(135deg,rgba(13,27,53,.9) 0%,rgba(21,35,71,.7) 100%);
  border:1px solid var(--border);border-radius:20px;overflow:hidden;
  box-shadow:var(--shadow),0 0 0 1px rgba(0,212,255,.04);
  position:relative;
}
.own-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--orange),var(--cyan),var(--yellow));
}
.own-card-inner{display:grid;grid-template-columns:auto 1fr;gap:0;align-items:stretch}
@media(max-width:640px){.own-card-inner{grid-template-columns:1fr}}
 
.own-left{
  padding:28px 28px 28px 32px;
  display:flex;align-items:center;gap:22px;
  border-right:1px solid var(--border);
  background:rgba(6,14,31,.3);
}
@media(max-width:640px){.own-left{border-right:none;border-bottom:1px solid var(--border);padding:24px;}}
 
.own-photo-ring{
  width:80px;height:80px;border-radius:50%;padding:2.5px;flex-shrink:0;
  background:linear-gradient(135deg,var(--orange),var(--cyan));
  box-shadow:0 0 20px rgba(0,212,255,.2);
}
.own-photo-ring img{width:100%;height:100%;border-radius:50%;object-fit:cover;object-position:top center;display:block}
 
.own-name-block{min-width:0}
.own-owner-label{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  color:var(--muted);margin-bottom:5px}
.own-name{font-size:18px;font-weight:800;letter-spacing:-.4px;white-space:nowrap}
.own-role{font-size:12px;color:var(--orange2);font-weight:600;margin-top:3px}
 
.own-right{
  padding:22px 28px;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  align-content:center;
}
@media(max-width:500px){.own-right{grid-template-columns:1fr}}
 
.own-item{display:flex;gap:10px;align-items:flex-start}
.own-icon{
  width:32px;height:32px;border-radius:8px;
  display:grid;place-items:center;font-size:14px;flex-shrink:0;
  border:1px solid var(--border);
}
.oi-eng{background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.25)}
.oi-lang{background:rgba(255,214,0,.1);border-color:rgba(255,214,0,.25)}
.oi-intl{background:rgba(255,107,53,.1);border-color:rgba(255,107,53,.25)}
.oi-work{background:rgba(0,230,118,.1);border-color:rgba(0,230,118,.25)}
.own-item-text{}
.own-item-title{font-size:12px;font-weight:600;line-height:1.4;color:var(--white)}
.own-item-detail{font-size:11px;color:var(--muted);margin-top:2px;line-height:1.4}
 
.own-footer{
  padding:10px 32px;
  background:rgba(6,14,31,.4);
  border-top:1px solid var(--border);
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;
}
.own-footer-dot{width:6px;height:6px;border-radius:50%;background:linear-gradient(135deg,var(--orange),var(--cyan));flex-shrink:0}
.own-footer-text{font-size:11px;color:var(--muted)}
.own-copyright{margin-left:auto;font-size:11px;color:var(--muted2);font-family:'IBM Plex Mono',monospace}
 
/* ── OVERALL PROGRESS ── */
.overall-progress{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:18px 24px;margin-bottom:28px;display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.op-label{font-size:13px;font-weight:600;white-space:nowrap}
.op-bar-wrap{flex:1;min-width:120px;height:7px;background:var(--border);border-radius:4px;overflow:hidden}
.op-bar{height:100%;background:linear-gradient(90deg,var(--orange),var(--cyan));border-radius:4px;transition:width .6s}
.op-text{font-size:12px;color:var(--muted);white-space:nowrap;font-family:'IBM Plex Mono',monospace}
 
/* ── GROUPS GRID ── */
.section-label{font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;
  color:var(--muted);margin-bottom:18px;display:flex;align-items:center;gap:12px}
.section-label::after{content:'';flex:1;height:1px;background:var(--border)}
.groups-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:14px}
.group-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  padding:20px;cursor:pointer;transition:all .22s;position:relative;overflow:hidden}
.group-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--orange),var(--cyan));transform:scaleX(0);
  transform-origin:left;transition:transform .3s}
.group-card:hover{border-color:rgba(0,212,255,.4);transform:translateY(-3px);box-shadow:var(--shadow)}
.group-card:hover::before{transform:scaleX(1)}
.group-card.completed{border-color:rgba(0,230,118,.3)}
.group-card.completed::before{transform:scaleX(1);background:var(--green)}
.group-num{font-size:11px;font-weight:600;letter-spacing:.8px;color:var(--muted);text-transform:uppercase;margin-bottom:8px}
.group-name{font-size:15px;font-weight:600;line-height:1.4;margin-bottom:14px}
.group-footer{display:flex;align-items:center;gap:8px}
.term-count{font-size:12px;color:var(--muted)}
.level-dots{display:flex;gap:5px;margin-left:auto}
.level-dot{width:22px;height:22px;border-radius:50%;border:1.5px solid var(--border);
  display:grid;place-items:center;font-size:9px;font-weight:700;color:var(--muted);transition:all .3s}
.level-dot.done-A{background:rgba(0,212,255,.2);border-color:var(--cyan);color:var(--cyan)}
.level-dot.done-B{background:rgba(255,107,53,.2);border-color:var(--orange);color:var(--orange)}
.level-dot.done-C{background:rgba(255,214,0,.2);border-color:var(--yellow);color:var(--yellow)}
 
/* ── GROUP PAGE ── */
.back-btn{display:inline-flex;align-items:center;gap:8px;color:var(--muted);font-size:14px;
  cursor:pointer;margin-bottom:28px;padding:8px 0;transition:color .2s;background:none;border:none}
.back-btn:hover{color:var(--white)}
.group-header{margin-bottom:28px}
.group-header h2{font-size:clamp(22px,4vw,36px);font-weight:800;letter-spacing:-1px;margin-bottom:6px}
.group-header p{color:var(--muted);font-size:14px}
 
/* ── LEVEL TABS ── */
.level-tabs{display:flex;gap:10px;margin-bottom:28px;flex-wrap:wrap}
.level-tab{display:flex;align-items:center;gap:10px;padding:14px 20px;border-radius:var(--radius);
  border:1px solid var(--border);background:var(--card);cursor:pointer;transition:all .2s;flex:1;min-width:130px}
.level-tab.active-A{border-color:var(--cyan);background:rgba(0,212,255,.1)}
.level-tab.active-B{border-color:var(--orange);background:rgba(255,107,53,.1)}
.level-tab.active-C{border-color:var(--yellow);background:rgba(255,214,0,.1)}
.level-icon{width:36px;height:36px;border-radius:10px;display:grid;place-items:center;
  font-size:16px;font-weight:700;flex-shrink:0;position:relative}
.icon-A{background:rgba(0,212,255,.2);color:var(--cyan)}
.icon-B{background:rgba(255,107,53,.2);color:var(--orange)}
.icon-C{background:rgba(255,214,0,.2);color:var(--yellow)}
.level-info{text-align:left}
.level-name{font-size:14px;font-weight:700}
.level-desc{font-size:11px;color:var(--muted);margin-top:2px}
.done-pill{display:inline-block;background:rgba(0,230,118,.15);border:1px solid rgba(0,230,118,.3);
  color:var(--green);font-size:10px;padding:2px 8px;border-radius:10px;margin-top:4px}
 
/* ── LEVEL CONTENT ── */
.level-content{display:none;animation:fadeUp .3s ease}
.level-content.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
 
/* ── FLASHCARD ── */
.flashcard-nav{display:flex;align-items:center;gap:16px;margin-bottom:18px}
.fc-progress{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.fc-progress-bar{height:100%;background:linear-gradient(90deg,var(--cyan),var(--cyan2));border-radius:3px;transition:width .4s}
.fc-counter{font-size:13px;color:var(--muted);white-space:nowrap;font-family:'IBM Plex Mono',monospace}
.flashcard{background:var(--card);border:1px solid var(--border);border-radius:18px;overflow:hidden;box-shadow:var(--shadow)}
.fc-top{padding:28px 28px 22px;display:flex;gap:24px;align-items:flex-start;flex-wrap:wrap}
.fc-img-wrap{width:200px;height:150px;border-radius:12px;overflow:hidden;flex-shrink:0;
  background:var(--navy3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center}
.fc-img-wrap img{width:100%;height:100%;object-fit:cover}
.fc-img-placeholder{font-size:42px}
.fc-main{flex:1;min-width:200px}
.fc-term{font-size:clamp(24px,4vw,40px);font-weight:800;letter-spacing:-1px;font-family:'IBM Plex Mono',monospace;color:var(--white);margin-bottom:6px}
.fc-khmer{font-size:20px;color:var(--cyan2);margin-bottom:14px;line-height:1.5}
.speak-btn{display:inline-flex;align-items:center;gap:8px;background:rgba(0,212,255,.12);
  border:1px solid rgba(0,212,255,.3);color:var(--cyan);font-size:13px;font-weight:600;
  padding:8px 18px;border-radius:20px;cursor:pointer;transition:all .2s;font-family:'Outfit',sans-serif}
.speak-btn:hover{background:rgba(0,212,255,.22)}
.speak-btn.speaking{animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.fc-divider{height:1px;background:var(--border);margin:0 28px}
.fc-bottom{padding:22px 28px 28px;display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:600px){.fc-bottom{grid-template-columns:1fr}.fc-top{flex-direction:column}.fc-img-wrap{width:100%;height:180px}}
.fc-section-label{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.fc-text{font-size:14px;line-height:1.75;color:#c8d4f0}
.fc-controls{display:flex;align-items:center;justify-content:space-between;margin-top:20px;flex-wrap:wrap;gap:12px}
.nav-btn{display:inline-flex;align-items:center;gap:8px;padding:11px 22px;border-radius:var(--radius-sm);
  font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;border:none;font-family:'Outfit',sans-serif}
.nav-btn.prev{background:var(--navy3);color:var(--muted);border:1px solid var(--border)}
.nav-btn.prev:hover{color:var(--white);border-color:var(--white)}
.nav-btn.next{background:linear-gradient(135deg,var(--cyan),#0099cc);color:#000;font-weight:700}
.nav-btn.next:hover{transform:translateX(3px)}
.nav-btn:disabled{opacity:.3;cursor:not-allowed;transform:none!important}
.all-done-banner{background:rgba(0,230,118,.1);border:1px solid rgba(0,230,118,.3);
  border-radius:var(--radius-sm);padding:10px 18px;font-size:13px;color:var(--green);font-weight:600}
 
/* ── QUIZ ── */
.quiz-wrap{max-width:700px;margin:0 auto}
.quiz-q{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:28px;margin-bottom:18px}
.quiz-q-label{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:12px}
.lbl-B{color:var(--orange)}.lbl-C{color:var(--yellow)}
.quiz-big-term{font-size:clamp(22px,4vw,34px);font-weight:800;font-family:'IBM Plex Mono',monospace;margin-bottom:10px}
.quiz-img{width:100%;max-height:200px;object-fit:cover;border-radius:10px;margin-top:12px;border:1px solid var(--border);background:var(--navy3)}
.quiz-def{font-size:15px;line-height:1.75;color:#c8d4f0}
.quiz-options{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:4px}
@media(max-width:540px){.quiz-options{grid-template-columns:1fr}}
.opt{border-radius:var(--radius-sm);padding:14px 16px;text-align:left;cursor:pointer;transition:all .2s;width:100%;font-family:'Outfit',sans-serif;font-size:14px;font-weight:500;color:var(--white)}
.opt-khmer{background:var(--navy3);border:1.5px solid var(--border);font-family:'Noto Serif Khmer',serif;font-size:15px}
.opt-eng{background:var(--navy3);border:1.5px solid var(--border);font-family:'IBM Plex Mono',monospace;font-weight:600}
.opt:hover:not(:disabled){transform:translateY(-1px)}
.opt-khmer:hover:not(:disabled){border-color:var(--orange);background:rgba(255,107,53,.08)}
.opt-eng:hover:not(:disabled){border-color:var(--yellow);background:rgba(255,214,0,.08)}
.opt.correct{border-color:var(--green)!important;background:rgba(0,230,118,.12)!important;color:var(--green)!important}
.opt.wrong{border-color:var(--red)!important;background:rgba(255,69,96,.12)!important;color:var(--red)!important}
.opt:disabled{cursor:not-allowed}
.quiz-feedback{margin-top:12px;font-size:14px;min-height:22px;font-weight:600}
.fb-ok{color:var(--green)}.fb-bad{color:var(--red)}
.quiz-nav-row{display:flex;justify-content:space-between;align-items:center;margin-top:18px;flex-wrap:wrap;gap:12px}
.q-counter{font-size:13px;color:var(--muted);font-family:'IBM Plex Mono',monospace}
 
/* ── SCORE ── */
.score-screen{text-align:center;padding:48px 24px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius)}
.score-ring{width:130px;height:130px;margin:0 auto 24px;position:relative}
.score-ring svg{transform:rotate(-90deg)}
.score-ring-text{position:absolute;inset:0;display:grid;place-items:center;font-size:28px;font-weight:800;font-family:'IBM Plex Mono',monospace}
.score-title{font-size:24px;font-weight:800;margin-bottom:8px}
.score-msg{font-size:15px;color:var(--muted);margin-bottom:28px;line-height:1.6}
.score-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.retry-btn{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,var(--orange),var(--orange2));
  color:white;font-size:14px;font-weight:700;padding:12px 26px;border-radius:var(--radius-sm);
  cursor:pointer;border:none;font-family:'Outfit',sans-serif;transition:transform .2s}
.retry-btn:hover{transform:scale(1.04)}
.next-group-btn{display:inline-flex;align-items:center;gap:8px;background:rgba(0,212,255,.12);
  border:1px solid rgba(0,212,255,.3);color:var(--cyan);font-size:14px;font-weight:700;
  padding:12px 26px;border-radius:var(--radius-sm);cursor:pointer;font-family:'Outfit',sans-serif;transition:all .2s}
.next-group-btn:hover{background:rgba(0,212,255,.22)}
 
/* ── FOOTER ── */
footer{
  position:relative;z-index:1;
  border-top:1px solid var(--border);
  background:rgba(6,14,31,.7);
  padding:28px 24px;
  margin-top:60px;
}
.footer-inner{
  max-width:1200px;margin:0 auto;
  display:flex;align-items:center;gap:16px;flex-wrap:wrap;
}
.footer-photo-ring{
  width:44px;height:44px;border-radius:50%;padding:2px;flex-shrink:0;
  background:linear-gradient(135deg,var(--orange),var(--cyan));
}
.footer-photo-ring img{width:100%;height:100%;border-radius:50%;object-fit:cover;object-position:top center;display:block}
.footer-info{flex:1;min-width:200px}
.footer-name{font-size:14px;font-weight:700}
.footer-role{font-size:11px;color:var(--muted);margin-top:2px}
.footer-copy{font-size:11px;color:var(--muted2);font-family:'IBM Plex Mono',monospace;margin-left:auto}
 
.hidden{display:none!important}
</style>
</head>
<body>
 
<!-- ══ HEADER ══ -->
<header>
  <div class="header-inner">
    <div class="logo">🔧</div>
    <div>
      <div class="site-title">Technical English–Khmer Dictionary</div>
      <div class="site-subtitle">Automotive Terminology · 1st-Year College Level</div>
    </div>
    <div class="header-right">
      <span style="font-size:11px;color:var(--muted)" id="hdr-progress"></span>
      <div class="header-badge">13 Groups · 130 Terms</div>
    </div>
  </div>
</header>
 
<div class="page">
 
<!-- ══ HOME ══ -->
<div id="home-page">
  <div class="hero">
    <div class="hero-eyebrow">🎓 Autobody Repair Program</div>
    <h1>Master the <span>Technical Vocabulary</span><br>of Automotive Work</h1>
    <p class="hero-sub">Learn automotive technical words, understand their Khmer translations, listen to pronunciation, and test yourself through 3 levels per group.</p>
    <div class="stats-row">
      <div class="stat"><div class="stat-n">13</div><div class="stat-l">Groups</div></div>
      <div class="stat"><div class="stat-n">130</div><div class="stat-l">Terms</div></div>
      <div class="stat"><div class="stat-n">3</div><div class="stat-l">Levels Each</div></div>
    </div>
  </div>
 
  <!-- ══ OWNERSHIP CARD ══ -->
  <div class="ownership-section">
    <div class="section-label">About the Instructor</div>
    <div class="own-card">
      <div class="own-card-inner">
 
